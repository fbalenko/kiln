# Kiln environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit your real keys.

# ────────────────────────────────────────────────────────────────────
# Phase 0+ (required from day one)
# ────────────────────────────────────────────────────────────────────

# Anthropic API key — for all agent inference (Orchestrator + 5 sub-agents)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used ONLY for embeddings (text-embedding-3-small)
# Agent inference uses Anthropic; this is just for vector search seed
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Exa API key — for fetching public customer signals
# Get one at: https://dashboard.exa.ai
EXA_API_KEY=...

# ────────────────────────────────────────────────────────────────────
# Phase 6+ (Slack integration)
# ────────────────────────────────────────────────────────────────────

# Slack bot user OAuth token (starts with xoxb-)
# Created when you install the Kiln Deal Desk app to your Slack workspace
SLACK_BOT_TOKEN=xoxb-...

# The channel ID of #deal-desk in the kiln-demo workspace (starts with C)
# Find it: right-click the channel → "View channel details" → bottom of the panel
SLACK_DEAL_DESK_CHANNEL_ID=C...

# ────────────────────────────────────────────────────────────────────
# App config
# ────────────────────────────────────────────────────────────────────

# The base URL of the running app
# Localhost for dev; switch to the deployed URL at Phase 10
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────────
# Phase 8 ONLY (live Google Sheets integration — deferred to post-launch)
# ────────────────────────────────────────────────────────────────────

# Service account JSON, base64-encoded
# Generate: cat key.json | base64 -w 0  (Linux)
#           cat key.json | base64        (Mac)
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# The Drive folder ID where copied workbooks land
# Folder URL: drive.google.com/drive/folders/<this-part>
GOOGLE_DRIVE_FOLDER_ID=

# The master template Sheet ID
# Sheet URL: docs.google.com/spreadsheets/d/<this-part>/edit
GOOGLE_SHEETS_TEMPLATE_ID=
